generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH & USERS ────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  BD_STAFF
  VIEWER
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String
  passwordHash  String?
  avatar        String?
  role          Role         @default(BD_STAFF)
  provider      AuthProvider @default(EMAIL)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Telegram binding
  telegramBindCode        String?   @unique
  telegramBindCodeExpiry  DateTime?

  // Relations
  assignedContacts Contact[]      @relation("AssignedContacts")
  assignedPipelines Pipeline[]    @relation("AssignedPipelines")
  actions          ContactAction[] @relation("PerformedActions")
  notifications    Notification[]
  auditLogs        AuditLog[]
  telegramBinding  TelegramBinding?
  campaigns        Campaign[]

  @@map("users")
}

// ─── COMPANIES ───────────────────────────────────────────

enum Industry {
  BANK
  FMCG
  MEDIA
  CONGLOMERATE
  TECH_DURABLE
  PHARMA_HEALTHCARE
  MANUFACTURING
  OTHERS
}

enum CompanySize {
  SME
  MID_MARKET
  ENTERPRISE
  LARGE_ENTERPRISE
}

model Company {
  id            String      @id @default(cuid())
  name          String
  industry      Industry    @default(OTHERS)
  phone         String?
  country       String?
  size          CompanySize?
  employeeCount String?
  annualSpend   String?
  fitScore      Int?        @db.SmallInt // 1-5
  primaryUseCase String?
  website       String?
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  contacts  Contact[]
  pipelines Pipeline[]

  @@map("companies")
}

// ─── CONTACTS ────────────────────────────────────────────

enum ContactStatus {
  NO_CONTACT       // 0. No Contact
  CONTACT          // 1. Contact
  REACHED          // 2. Reached
  FOLLOW_UP        // 3. Follow-up
  MEETING_BOOKED   // 4. Meeting Booked
  CONVERTED        // 5. Converted
}

enum ContactSource {
  CURRENT_XPERISE
  DESK_RESEARCH
  PERSONAL_REFERRAL
  APOLLO
  OTHER
}

enum ContactType {
  SNIPING
  HUNTING
}

enum EmailVerifyStatus {
  VALID
  INVALID
  UNKNOWN
  ACCEPT_ALL
}

model Contact {
  id              String            @id @default(cuid())
  fullName        String
  position        String?
  email           String?
  phone           String?
  linkedin        String?
  source          ContactSource     @default(OTHER)
  priority        Int               @default(3) @db.SmallInt // 1-5
  type            ContactType       @default(HUNTING)
  contactStatus   ContactStatus     @default(NO_CONTACT)
  emailVerify     EmailVerifyStatus @default(UNKNOWN)
  notes           String?
  lastTouchedAt   DateTime?         // Updated when any ContactAction is logged
  enrichmentData  Json?             // Apollo enrichment cache — check before calling API
  nextActionAt    DateTime?         // Next scheduled follow-up
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  company     Company         @relation(fields: [companyId], references: [id])
  companyId   String
  assignedTo  User?           @relation("AssignedContacts", fields: [assignedToId], references: [id])
  assignedToId String?
  actions     ContactAction[]
  emailLogs   EmailLog[]
  campaignRecipients CampaignRecipient[]

  @@index([companyId])
  @@index([assignedToId])
  @@index([contactStatus])
  @@index([priority])
  @@map("contacts")
}

// ─── CONTACT ACTIONS ─────────────────────────────────────

enum ActionType {
  EMAIL_SENT
  EMAIL_FOLLOW_UP
  LINKEDIN_MESSAGE
  LINKEDIN_CONNECT
  PHONE_CALL
  MEETING
  NOTE
  STATUS_CHANGE
  OTHER
}

enum ActionStatus {
  DONE
  FOLLOW_UP
  PENDING
  NOT_STARTED
}

model ContactAction {
  id          String       @id @default(cuid())
  type        ActionType
  status      ActionStatus @default(DONE)
  note        String?
  metadata    Json?        // Flexible data (email subject, meeting link, etc.)
  performedAt DateTime     @default(now())
  createdAt   DateTime     @default(now())

  // Relations
  contact       Contact @relation(fields: [contactId], references: [id])
  contactId     String
  performedBy   User    @relation("PerformedActions", fields: [performedById], references: [id])
  performedById String

  @@index([contactId])
  @@index([performedById])
  @@map("contact_actions")
}

// ─── PIPELINES ───────────────────────────────────────────

enum DealStage {
  NEW_CONVERTED    // 0. New Converted (0%)
  MEETING          // 2. Meeting/Presentation (10%)
  PROPOSAL         // 3. Proposal (25%)
  PILOT_POC        // 4. Pilot/PoC (67%)
  NEGOTIATION      // 5. Negotiation (90%)
  CLOSED_WON       // 6. Closed Won (100%)
  CLOSED_LOST      // 7. Closed Lost (0%)
}

model Pipeline {
  id             String    @id @default(cuid())
  dealStage      DealStage @default(NEW_CONVERTED)
  totalRevenue   BigInt    @default(0) // VND
  probability    Float     @default(0)
  monthlyRevenue Json?     // { "jan26": 0, "feb26": 0, ... }
  status         String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  company   Company @relation(fields: [companyId], references: [id])
  companyId String
  pic       User?   @relation("AssignedPipelines", fields: [picId], references: [id])
  picId     String?

  @@index([companyId])
  @@index([dealStage])
  @@map("pipelines")
}

// ─── CAMPAIGNS (Phase 2) ─────────────────────────────────

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum EmailStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENDING
  SENT
  OPENED
  REPLIED
  BOUNCED
  REJECTED
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  status      CampaignStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  createdBy   User           @relation(fields: [createdById], references: [id])
  createdById String
  steps       CampaignStep[]
  recipients  CampaignRecipient[]
  emailLogs   EmailLog[]

  @@map("campaigns")
}

model CampaignStep {
  id         String   @id @default(cuid())
  stepOrder  Int      // 0 = initial email, 1 = follow-up 1, ...
  delayDays  Int      @default(0) // days after previous step
  subject    String
  body       String   @db.Text
  createdAt  DateTime @default(now())

  // Relations
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String

  @@unique([campaignId, stepOrder])
  @@map("campaign_steps")
}

model CampaignRecipient {
  id          String      @id @default(cuid())
  currentStep Int         @default(0)
  status      EmailStatus @default(DRAFT)
  nextSendAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  contact    Contact  @relation(fields: [contactId], references: [id])
  contactId  String

  @@unique([campaignId, contactId])
  @@index([status])
  @@index([nextSendAt])
  @@map("campaign_recipients")
}

// ─── EMAIL LOGS (Phase 2-3) ──────────────────────────────

model EmailLog {
  id         String      @id @default(cuid())
  subject    String
  body       String?     @db.Text
  status     EmailStatus @default(SENT)
  stepOrder  Int?
  sentAt     DateTime    @default(now())
  openedAt   DateTime?
  repliedAt  DateTime?
  bouncedAt  DateTime?
  trackToken String?     @unique // for open/click tracking
  metadata   Json?       // tracking data
  createdAt  DateTime    @default(now())

  // Relations
  contact    Contact  @relation(fields: [contactId], references: [id])
  contactId  String
  campaign   Campaign? @relation(fields: [campaignId], references: [id])
  campaignId String?

  @@index([contactId])
  @@index([campaignId])
  @@index([trackToken])
  @@map("email_logs")
}

// ─── NOTIFICATIONS ───────────────────────────────────────

enum NotificationType {
  STATUS_CHANGE
  ASSIGNMENT
  EMAIL_REPLY
  MEETING_BOOKED
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@index([userId, read])
  @@map("notifications")
}

// ─── AUDIT LOG ───────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // create, update, delete
  entity    String   // contact, company, pipeline
  entityId  String
  changes   Json?    // { field: { old: x, new: y } }
  createdAt DateTime @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id])
  userId String

  @@index([entity, entityId])
  @@index([userId])
  @@map("audit_logs")
}

// ─── TELEGRAM INTEGRATION ─────────────────────────────

model TelegramBinding {
  id           String   @id @default(cuid())
  telegramId   String   @unique
  telegramName String?
  chatId       String?  // private chat ID for DMs
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boundAt      DateTime @default(now())

  @@map("telegram_bindings")
}

model TelegramGroup {
  id        String   @id @default(cuid())
  chatId    String   @unique  // Telegram group chat ID (e.g., -1001234567890)
  name      String             // Group title from Telegram
  isActive  Boolean  @default(false)
  addedAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("telegram_groups")
}

model ColdLeadAlert {
  id        String   @id @default(cuid())
  contactId String
  sentAt    DateTime @default(now())

  @@index([contactId])
  @@index([sentAt])
  @@map("cold_lead_alerts")
}
